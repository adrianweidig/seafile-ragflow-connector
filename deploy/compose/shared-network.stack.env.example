# ---------------------------------------------------------------------
# Anwendungsfall: bestehendes Docker-Netz mit Seafile/RAGFlow
# ---------------------------------------------------------------------
# Nutze diese Env-Datei mit deploy/compose/shared-network.compose.yml.
# Das angegebene Docker-Netz muss bereits existieren.

COMPOSE_PROJECT_NAME=seafile-ragflow-connector-shared
TZ=Europe/Berlin
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
DRY_RUN=false

CONNECTOR_IMAGE=ghcr.io/adrianweidig/seafile-ragflow-connector:latest
POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7

# Gemeinsames Docker-Netz, in dem Seafile/RAGFlow bereits laufen.
CONNECTOR_DOCKER_NETWORK_NAME=change-me-existing-network

# Dashboard lokal veröffentlichen, falls aktiviert.
CONNECTOR_DASHBOARD_ENABLED=false
CONNECTOR_DASHBOARD_HOST=0.0.0.0
CONNECTOR_DASHBOARD_PORT=8080
CONNECTOR_DASHBOARD_PUBLISHED_PORT=127.0.0.1:18080

# Seafile per Docker-Service-Name. Download-URLs werden häufig umgeschrieben,
# weil Seafile intern Links mit 127.0.0.1/seafhttp erzeugen kann.
SEAFILE_BASE_URL=http://seafile
SEAFILE_INTERNAL_URL=
SEAFILE_ADMIN_TOKEN=change-me
SEAFILE_SYNC_USER_TOKEN=change-me
SEAFILE_SYNC_USER_EMAIL=ragflow-sync@example.local
SEAFILE_REWRITE_DOWNLOAD_URLS=true
SEAFILE_DOWNLOAD_REWRITE_FROM=http://127.0.0.1/seafhttp
SEAFILE_DOWNLOAD_REWRITE_TO=http://seafile/seafhttp

# RAGFlow per Docker-Service-Name.
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_INTERNAL_URL=
RAGFLOW_API_KEY=change-me
RAGFLOW_TEMPLATE_DATASET_NAME=connector_template
RAGFLOW_TEMPLATE_REQUIRED=true
RAGFLOW_PUBLIC_BASE_URL=
RAGFLOW_DOCUMENT_URL_TEMPLATE=

# OpenWebUI ist in dieser Variante aus.
OPENWEBUI_INTEGRATION_ENABLED=false
OPENWEBUI_SYNC_MODE=disabled

POSTGRES_DB=seafile_ragflow_sync
POSTGRES_USER=sync
POSTGRES_PASSWORD=change-me
REDIS_DB=0

DELETE_RAGFLOW_DOCS_ON_SEAFILE_DELETE=true
DELETE_DATASET_WHEN_LIBRARY_DELETED=true
ARCHIVE_DATASET_WHEN_LIBRARY_DELETED=false

CONNECTOR_AUTO_INIT_DB=true
CONNECTOR_STARTUP_CHECK=live
CONNECTOR_BOOTSTRAP_CHECK_LIVE=true
