# ---------------------------------------------------------------------
# Anwendungsfall: Seafile/RAGFlow extern über Host, LAN oder Reverse Proxy
# ---------------------------------------------------------------------
# Nutze diese Env-Datei mit deploy/compose/external-services.compose.yml.
# Alle "change-me" Werte müssen vor dem produktiven Start ersetzt werden.

COMPOSE_PROJECT_NAME=seafile-ragflow-connector-external
TZ=Europe/Berlin
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
DRY_RUN=false

# Images: Standard ist GHCR. Für Offline-Betrieb hier ein lokal geladenes
# Image oder eine interne Registry eintragen.
CONNECTOR_IMAGE=ghcr.io/adrianweidig/seafile-ragflow-connector:latest
POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7

# Dashboard: Für manuelle Tests aktiv. Es bleibt lokal auf dem Host gebunden.
# Für LAN-Zugriff z. B. CONNECTOR_DASHBOARD_PUBLISHED_PORT=18080.
CONNECTOR_DASHBOARD_ENABLED=true
CONNECTOR_DASHBOARD_HOST=0.0.0.0
CONNECTOR_DASHBOARD_PORT=8080
CONNECTOR_DASHBOARD_PUBLISHED_PORT=127.0.0.1:18080

# Seafile muss aus dem Connector-Container erreichbar sein.
SEAFILE_BASE_URL=http://host.docker.internal:18081
SEAFILE_INTERNAL_URL=
SEAFILE_ADMIN_TOKEN=change-me
SEAFILE_SYNC_USER_TOKEN=change-me
SEAFILE_SYNC_USER_EMAIL=ragflow-sync@example.local
SEAFILE_REWRITE_DOWNLOAD_URLS=false
SEAFILE_DOWNLOAD_REWRITE_FROM=
SEAFILE_DOWNLOAD_REWRITE_TO=

# RAGFlow muss aus dem Connector-Container erreichbar sein.
RAGFLOW_BASE_URL=http://host.docker.internal:19380
RAGFLOW_INTERNAL_URL=
RAGFLOW_API_KEY=change-me
RAGFLOW_TEMPLATE_DATASET_NAME=connector_template
RAGFLOW_TEMPLATE_REQUIRED=true
RAGFLOW_PUBLIC_BASE_URL=
RAGFLOW_DOCUMENT_URL_TEMPLATE=

# OpenWebUI ist in dieser Variante bewusst deaktiviert.
OPENWEBUI_INTEGRATION_ENABLED=false
OPENWEBUI_SYNC_MODE=disabled

# Connector-State.
POSTGRES_DB=seafile_ragflow_sync
POSTGRES_USER=sync
POSTGRES_PASSWORD=change-me
REDIS_DB=0

# Delete-/Repair-Policy. Seafile bleibt Quelle der Wahrheit.
DELETE_RAGFLOW_DOCS_ON_SEAFILE_DELETE=true
DELETE_DATASET_WHEN_LIBRARY_DELETED=true
ARCHIVE_DATASET_WHEN_LIBRARY_DELETED=false

# Startup-Prüfung: live prüft zusätzlich Seafile/RAGFlow.
CONNECTOR_AUTO_INIT_DB=true
CONNECTOR_STARTUP_CHECK=live
CONNECTOR_BOOTSTRAP_CHECK_LIVE=true
