# ---------------------------------------------------------------------
# Anwendungsfall: Seafile/RAGFlow plus OpenWebUI im gemeinsamen Docker-Netz
# ---------------------------------------------------------------------
# Nutze diese Env-Datei mit deploy/compose/openwebui.compose.yml.
# Starte zuerst mit OPENWEBUI_SYNC_MODE=dry-run und prüfe das Dashboard.

COMPOSE_PROJECT_NAME=seafile-ragflow-connector-openwebui
TZ=Europe/Berlin
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
DRY_RUN=false

CONNECTOR_IMAGE=ghcr.io/adrianweidig/seafile-ragflow-connector:latest
POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7

# Gemeinsames Docker-Netz mit Seafile, RAGFlow und OpenWebUI.
CONNECTOR_DOCKER_NETWORK_NAME=change-me-existing-network

# Dashboard/Proxy. Für produktiven Zugriff Reverse Proxy oder Netzwerkregeln
# davor setzen; das Dashboard selbst ist lesend und unauthentifiziert.
CONNECTOR_DASHBOARD_ENABLED=true
CONNECTOR_DASHBOARD_HOST=0.0.0.0
CONNECTOR_DASHBOARD_PORT=8080
CONNECTOR_DASHBOARD_PUBLISHED_PORT=127.0.0.1:18080

SEAFILE_BASE_URL=http://seafile
SEAFILE_INTERNAL_URL=
SEAFILE_ADMIN_TOKEN=change-me
SEAFILE_SYNC_USER_TOKEN=change-me
SEAFILE_SYNC_USER_EMAIL=ragflow-sync@example.local
SEAFILE_REWRITE_DOWNLOAD_URLS=true
SEAFILE_DOWNLOAD_REWRITE_FROM=http://127.0.0.1/seafhttp
SEAFILE_DOWNLOAD_REWRITE_TO=http://seafile/seafhttp

RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_INTERNAL_URL=
RAGFLOW_API_KEY=change-me
RAGFLOW_TEMPLATE_DATASET_NAME=connector_template
RAGFLOW_TEMPLATE_REQUIRED=true
RAGFLOW_PUBLIC_BASE_URL=
RAGFLOW_DOCUMENT_URL_TEMPLATE=

# OpenWebUI: Admin-Key nie in generierten Tools/Pipes speichern. Er wird nur vom
# Connector für die Admin-API genutzt.
OPENWEBUI_INTEGRATION_ENABLED=true
OPENWEBUI_BASE_URL=http://openwebui:8080
OPENWEBUI_ADMIN_API_KEY=change-me
OPENWEBUI_SYNC_ON_STARTUP=true
# Erst dry-run, dann sync oder repair.
OPENWEBUI_SYNC_MODE=dry-run
OPENWEBUI_CREATE_TOOLS=true
OPENWEBUI_CREATE_PIPES=true
OPENWEBUI_FUNCTION_NAMESPACE=ragflow
OPENWEBUI_SOURCE_PREVIEW_MODE=connector_viewer
OPENWEBUI_PROXY_PUBLIC_BASE_URL=http://localhost:18080
OPENWEBUI_PROXY_INTERNAL_BASE_URL=http://connector-controller:8080
OPENWEBUI_PROXY_SHARED_SECRET=change-me
OPENWEBUI_SYNC_INTERVAL_SECONDS=300
OPENWEBUI_DATASET_ALLOWLIST=

POSTGRES_DB=seafile_ragflow_sync
POSTGRES_USER=sync
POSTGRES_PASSWORD=change-me
REDIS_DB=0

DELETE_RAGFLOW_DOCS_ON_SEAFILE_DELETE=true
DELETE_DATASET_WHEN_LIBRARY_DELETED=true
ARCHIVE_DATASET_WHEN_LIBRARY_DELETED=false

CONNECTOR_AUTO_INIT_DB=true
CONNECTOR_STARTUP_CHECK=live
CONNECTOR_BOOTSTRAP_CHECK_LIVE=true
