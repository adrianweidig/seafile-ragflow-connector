# ---------------------------------------------------------------------
# Docker Swarm ENV für deploy/swarm/docker-stack.yml
# ---------------------------------------------------------------------
# Diese Datei wird nicht direkt von docker stack deploy gelesen. Vor dem Deploy:
#
#   cp ../../connector.env.example stack.env
#   # Für Swarm CONNECTOR_DASHBOARD_PUBLISHED_PORT auf eine Portnummer setzen.
#   set -a
#   . ./stack.env
#   set +a
#   docker stack deploy -c docker-stack.yml seafile-ragflow-connector

TZ=Europe/Berlin
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
DRY_RUN=false

CONNECTOR_IMAGE=ghcr.io/adrianweidig/seafile-ragflow-connector:latest
POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7
CONNECTOR_CERTS_HOST_DIR=./certs
CONNECTOR_CA_BUNDLE=
SSL_CERT_FILE=
REQUESTS_CA_BUNDLE=

# Name des internen Overlay-Netzes für Connector, PostgreSQL und Redis.
CONNECTOR_SWARM_NETWORK_NAME=seafile-ragflow-connector-net

# Im Swarm nur eine Portnummer eintragen, keine Bind-Adresse.
CONNECTOR_DASHBOARD_ENABLED=true
CONNECTOR_DASHBOARD_HOST=0.0.0.0
CONNECTOR_DASHBOARD_PORT=8080
CONNECTOR_DASHBOARD_PUBLISHED_PORT=18080
CONNECTOR_DASHBOARD_AUTH_USERNAME=admin
CONNECTOR_DASHBOARD_AUTH_PASSWORD=change-me-dashboard-password

# Interne Authz-API und ACL-Snapshot.
AUTHZ_API_ENABLED=true
AUTHZ_API_SHARED_SECRET=change-me-authz-secret
AUTHZ_API_ALLOW_NETWORKS=
AUTHZ_API_FAIL_CLOSED=true
AUTHZ_API_MAX_ACL_AGE_SECONDS=7200

SEARCH_ACL_SYNC_ENABLED=true
SEARCH_ACL_SYNC_INTERVAL_SECONDS=1800
SEARCH_ACL_INCLUDE_SUBFOLDER_PERMISSIONS=false
SEARCH_ACL_INCLUDE_SHARE_LINKS=false

# Search-Service. Im Swarm nur eine Portnummer eintragen, keine Bind-Adresse.
SEARCH_SERVICE_ENABLED=true
SEARCH_SERVICE_HOST=0.0.0.0
SEARCH_SERVICE_PORT=8090
SEARCH_SERVICE_PUBLISHED_PORT=18090
SEARCH_AUTH_MODE=trusted_header
SEARCH_TRUSTED_USERNAME_HEADER=X-Forwarded-User
SEARCH_TRUSTED_EMAIL_HEADER=X-Forwarded-Email
SEARCH_TRUSTED_DISPLAY_NAME_HEADER=X-Forwarded-Name
SEARCH_AUTHZ_BASE_URL=http://connector-controller:8080
SEARCH_AUTHZ_SHARED_SECRET=change-me-authz-secret
SEARCH_RAGFLOW_BASE_URL=http://ragflow.example.local:9380
SEARCH_RAGFLOW_API_KEY=change-me
SEARCH_RAGFLOW_VERIFY_SSL=true
SEARCH_RAGFLOW_CA_BUNDLE=
SEARCH_SEAFILE_PUBLIC_BASE_URL=
SEARCH_SEAFILE_FILE_URL_TEMPLATE=
SEARCH_DEFAULT_TOP_K=8
SEARCH_MAX_TOP_K=20
SEARCH_MAX_SELECTED_PROFILES=25
SEARCH_ENABLE_CHAT_MODE=true
SEARCH_ENABLE_RETRIEVAL_MODE=true

# Seafile muss aus den Swarm-Tasks erreichbar sein, z. B. über Reverse Proxy,
# LAN-IP oder DNS. Der Connector schreibt nie nach Seafile.
SEAFILE_BASE_URL=http://seafile.example.local
SEAFILE_INTERNAL_URL=
SEAFILE_ADMIN_TOKEN=change-me
SEAFILE_SYNC_USER_TOKEN=change-me
SEAFILE_SYNC_USER_EMAIL=ragflow-sync@example.local
SEAFILE_VERIFY_SSL=true
SEAFILE_CA_BUNDLE=
SEAFILE_CLIENT_CERT_FILE=
SEAFILE_CLIENT_KEY_FILE=
SEAFILE_REWRITE_DOWNLOAD_URLS=false
SEAFILE_DOWNLOAD_REWRITE_FROM=
SEAFILE_DOWNLOAD_REWRITE_TO=
SEAFILE_PUBLIC_BASE_URL=
# Optionaler Override für abweichende Seafile-Webrouten in OpenWebUI-Quellenpreviews.
SEAFILE_FILE_URL_TEMPLATE=

# RAGFlow-Zielsystem.
RAGFLOW_BASE_URL=http://ragflow.example.local:9380
RAGFLOW_INTERNAL_URL=
RAGFLOW_API_KEY=change-me
RAGFLOW_TEMPLATE_DATASET_NAME=connector_template
RAGFLOW_TEMPLATE_REQUIRED=true
RAGFLOW_VERIFY_SSL=true
RAGFLOW_CA_BUNDLE=
RAGFLOW_CLIENT_CERT_FILE=
RAGFLOW_CLIENT_KEY_FILE=
RAGFLOW_PUBLIC_BASE_URL=
RAGFLOW_DOCUMENT_URL_TEMPLATE=

# Optional. Minimalbetrieb synchronisiert nur Seafile -> RAGFlow.
OPENWEBUI_INTEGRATION_ENABLED=false
OPENWEBUI_BASE_URL=http://openwebui.example.local
OPENWEBUI_ADMIN_API_KEY=
OPENWEBUI_SYNC_ON_STARTUP=true
OPENWEBUI_SYNC_MODE=disabled
OPENWEBUI_CREATE_TOOLS=true
OPENWEBUI_CREATE_PIPES=true
# 180 Sekunden unterstützt lange RAG-Antworten. Für latenzkritische
# OpenWebUI-Proxy-/Edge-Flows 30-60 Sekunden wählen.
OPENWEBUI_REQUEST_TIMEOUT_SECONDS=180
OPENWEBUI_VERIFY_SSL=true
OPENWEBUI_CA_BUNDLE=
OPENWEBUI_FUNCTION_NAMESPACE=ragflow
OPENWEBUI_SOURCE_PREVIEW_MODE=ragflow_link
OPENWEBUI_PROXY_PUBLIC_BASE_URL=
OPENWEBUI_PROXY_INTERNAL_BASE_URL=http://connector-controller:8080
OPENWEBUI_PROXY_SHARED_SECRET=
OPENWEBUI_AUTHZ_ENABLED=true
OPENWEBUI_AUTHZ_BASE_URL=http://connector-controller:8080
OPENWEBUI_AUTHZ_SHARED_SECRET=change-me-authz-secret
OPENWEBUI_AUTHZ_FAIL_CLOSED=true
OPENWEBUI_PROXY_VERIFY_SSL=true
OPENWEBUI_PROXY_CA_BUNDLE=
CONNECTOR_PROXY_VERIFY_SSL=
CONNECTOR_PROXY_CA_BUNDLE=
CONNECTOR_PROXY_CLIENT_CERT_FILE=
CONNECTOR_PROXY_CLIENT_KEY_FILE=
OPENWEBUI_SYNC_INTERVAL_SECONDS=1800
OPENWEBUI_DATASET_ALLOWLIST=

POSTGRES_DB=seafile_ragflow_sync
POSTGRES_USER=sync
POSTGRES_PASSWORD=change-me
REDIS_DB=0

DELETE_RAGFLOW_DOCS_ON_SEAFILE_DELETE=true
DELETE_DATASET_WHEN_LIBRARY_DELETED=true
ARCHIVE_DATASET_WHEN_LIBRARY_DELETED=false

CONNECTOR_AUTO_INIT_DB=true
CONNECTOR_STARTUP_CHECK=infra
CONNECTOR_BOOTSTRAP_CHECK_LIVE=false
