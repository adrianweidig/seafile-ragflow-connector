# ---------------------------------------------------------------------
# Seafile RAGFlow Connector - zentrale Installationskonfiguration
# ---------------------------------------------------------------------
# Kopiere diese Datei zu connector.env und setze nur die Pflichtwerte, die zu
# deinem Betriebsmodus gehören. Dieselbe Datei kann für Docker Compose und
# Portainer genutzt werden.
#
# Minimalpflicht für Seafile -> RAGFlow mit Stack-Postgres:
#   SEAFILE_BASE_URL
#   SEAFILE_ADMIN_TOKEN
#   SEAFILE_SYNC_USER_TOKEN
#   RAGFLOW_BASE_URL
#   RAGFLOW_API_KEY
#   POSTGRES_PASSWORD
#
# Statt POSTGRES_PASSWORD kann DATABASE_URL gesetzt werden. OpenWebUI-Werte
# sind nur Pflicht, wenn OPENWEBUI_INTEGRATION_ENABLED=true und
# OPENWEBUI_SYNC_MODE=sync oder repair genutzt wird.

COMPOSE_PROJECT_NAME=seafile-ragflow-connector
TZ=Europe/Berlin
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
DRY_RUN=false
# Sprache für menschenlesbare CLI-, Dashboard- und OpenWebUI-Ausgaben.
# Unterstützt: de, en, es, fr, it, pt, nl, pl, tr, uk, zh, ja, ar.
# Leer oder unbekannt fällt stabil auf Deutsch zurück.
CONNECTOR_LANGUAGE=de

# ---------------------------------------------------------------------
# Images
# ---------------------------------------------------------------------
# Online-Start: GHCR-Image nutzen. Für produktionsnahe Deployments nach Release
# auf einen festen SemVer-Tag pinnen, z. B.
# ghcr.io/adrianweidig/seafile-ragflow-connector:2.4.11.
# "latest" ist eine Komfortoption für Smoke-Tests und frische Testumgebungen.
# Offline-Start: Images vorher mit docker load importieren und hier lokale
# Image-Namen oder interne Registry-Tags eintragen.
CONNECTOR_IMAGE=ghcr.io/adrianweidig/seafile-ragflow-connector:latest
POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7
# missing = vorhandenes lokales Image verwenden und nur pullen, wenn es fehlt.
# never   = nie pullen; sinnvoll, wenn alle Images vorher in Portainer/Docker
#           importiert wurden.
CONNECTOR_IMAGE_PULL_POLICY=missing
POSTGRES_IMAGE_PULL_POLICY=missing
REDIS_IMAGE_PULL_POLICY=missing

# ---------------------------------------------------------------------
# TLS / interne Zertifizierungsstellen
# ---------------------------------------------------------------------
# Schnellpfad für Unternehmensnetze:
#   bash scripts/configure-enterprise-compose.sh
# erzeugt connector.env plus passende Compose-Startskripte und nutzt
# deploy/compose/enterprise-ca.compose.yml als CA-Overlay.
#
# Wenn Seafile, RAGFlow oder OpenWebUI ein internes/self-signed Zertifikat
# nutzen und der Connector "unable to get local issuer certificate" meldet:
# 1. PEM-Datei mit Root-/Intermediate-CA auf dem Docker-Host ablegen.
# 2. CONNECTOR_CERTS_HOST_DIR auf dieses Host-Verzeichnis setzen.
# 3. CONNECTOR_CA_BUNDLE oder die service-spezifischen *_CA_BUNDLE Pfade auf
#    den Containerpfad setzen, z. B. /certs/company-root-ca.pem.
CONNECTOR_CERTS_HOST_DIR=./certs
# Direkter Host-Datei-Mount für das Enterprise-Overlay. Dieser Wert ist der
# absolute Pfad auf dem Docker-Host, nicht im Container.
CONNECTOR_ENTERPRISE_CA_HOST_FILE=
CONNECTOR_ENTERPRISE_CA_CONTAINER_FILE=/certs/company-root-ca.pem
CONNECTOR_CA_BUNDLE=
CONNECTOR_SYSTEM_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
SSL_CERT_FILE=
REQUESTS_CA_BUNDLE=

# Nur im absoluten Notfall auf false setzen. Besser ist ein CA-Bundle.
SEAFILE_VERIFY_SSL=true
SEAFILE_CA_BUNDLE=
SEAFILE_CLIENT_CERT_FILE=
SEAFILE_CLIENT_KEY_FILE=
RAGFLOW_VERIFY_SSL=true
RAGFLOW_CA_BUNDLE=
RAGFLOW_CLIENT_CERT_FILE=
RAGFLOW_CLIENT_KEY_FILE=
OPENWEBUI_VERIFY_SSL=true
OPENWEBUI_CA_BUNDLE=

# Betrifft die von OpenWebUI ausgeführten Tools/Pipes beim Zugriff auf den
# Connector-Proxy. Der CA-Pfad muss im OpenWebUI-Container existieren.
OPENWEBUI_PROXY_VERIFY_SSL=true
OPENWEBUI_PROXY_CA_BUNDLE=
# Aliasnamen für die OpenWebUI-Pipe-Strecke. Wenn beide Varianten gesetzt
# sind, hat OPENWEBUI_PROXY_* Vorrang in dieser Beispielkonfiguration.
CONNECTOR_PROXY_VERIFY_SSL=
CONNECTOR_PROXY_CA_BUNDLE=
CONNECTOR_PROXY_CLIENT_CERT_FILE=
CONNECTOR_PROXY_CLIENT_KEY_FILE=

# ---------------------------------------------------------------------
# Netzwerk
# ---------------------------------------------------------------------
# false = eigenes Connector-Netz; Seafile/RAGFlow/OpenWebUI werden über LAN,
#         Reverse Proxy oder host.docker.internal erreicht.
# true  = vorhandenes Docker-Netz nutzen; CONNECTOR_DOCKER_NETWORK_NAME muss
#         auf ein existierendes Netz zeigen.
CONNECTOR_DOCKER_NETWORK_EXTERNAL=false
CONNECTOR_DOCKER_NETWORK_NAME=seafile-ragflow-connector-net
CONNECTOR_SWARM_NETWORK_NAME=seafile-ragflow-connector-net

# ---------------------------------------------------------------------
# Lesendes Dashboard und OpenWebUI-Proxy
# ---------------------------------------------------------------------
# HTTP Basic Auth ist aktiv, sobald Benutzername und Passwort gesetzt sind.
# Setze in produktiven oder im LAN erreichbaren Umgebungen ein eigenes Passwort.
CONNECTOR_DASHBOARD_ENABLED=true
CONNECTOR_DASHBOARD_HOST=0.0.0.0
CONNECTOR_DASHBOARD_PORT=8080
CONNECTOR_DASHBOARD_PUBLISHED_PORT=127.0.0.1:18080
CONNECTOR_DASHBOARD_MAX_LOG_ENTRIES=5000
CONNECTOR_DASHBOARD_MAX_EVENT_ENTRIES=10000
CONNECTOR_DASHBOARD_MAX_SYNC_RUNS=1000
CONNECTOR_DASHBOARD_LOG_PAGE_SIZE=100
CONNECTOR_DASHBOARD_MAX_FIELD_LENGTH=4000
CONNECTOR_DASHBOARD_AUTH_USERNAME=admin
CONNECTOR_DASHBOARD_AUTH_PASSWORD=change-me-dashboard-password

# ---------------------------------------------------------------------
# Interne Autorisierungs-API und ACL-Snapshot
# ---------------------------------------------------------------------
# Die Authz-API gehört zum Connector-Core. Search-Service und OpenWebUI-Pipe
# authentifizieren sich technisch mit AUTHZ_API_SHARED_SECRET, übergeben aber
# die echte Nutzeridentität separat im Request. Dieses Secret ist kein Ersatz
# für Benutzeridentität.
AUTHZ_API_ENABLED=true
AUTHZ_API_SHARED_SECRET=change-me-authz-secret
AUTHZ_API_ALLOW_NETWORKS=
AUTHZ_API_FAIL_CLOSED=true
AUTHZ_API_MAX_ACL_AGE_SECONDS=7200

# ACLs werden ausschließlich aus Seafile-Bibliotheksrechten gespiegelt.
# Unterordnerrechte und Share-Links bleiben bewusst unberücksichtigt.
SEARCH_ACL_SYNC_ENABLED=true
SEARCH_ACL_SYNC_INTERVAL_SECONDS=1800
SEARCH_ACL_INCLUDE_SUBFOLDER_PERMISSIONS=false
SEARCH_ACL_INCLUDE_SHARE_LINKS=false

# ---------------------------------------------------------------------
# Nutzernahe Search-Webseite
# ---------------------------------------------------------------------
# Dieser Dienst läuft als separater Container mit `connector search-server`.
# Er benötigt keinen Seafile-Admin- oder Sync-Token. Vor jeder RAGFlow-Abfrage
# fragt er die Authz-API des Connector-Cores.
SEARCH_SERVICE_ENABLED=true
SEARCH_SERVICE_HOST=0.0.0.0
SEARCH_SERVICE_PORT=8090
SEARCH_SERVICE_PUBLISHED_PORT=127.0.0.1:18090

SEARCH_AUTH_MODE=trusted_header
SEARCH_TRUSTED_USERNAME_HEADER=X-Forwarded-User
SEARCH_TRUSTED_EMAIL_HEADER=X-Forwarded-Email
SEARCH_TRUSTED_DISPLAY_NAME_HEADER=X-Forwarded-Name

SEARCH_AUTHZ_BASE_URL=http://connector-controller:8080
SEARCH_AUTHZ_SHARED_SECRET=change-me-authz-secret

SEARCH_RAGFLOW_BASE_URL=http://ragflow:9380
SEARCH_RAGFLOW_API_KEY=change-me
SEARCH_RAGFLOW_VERIFY_SSL=true
SEARCH_RAGFLOW_CA_BUNDLE=
SEARCH_RAGFLOW_TEMPLATE_SOURCE_ORDER=search_app,chat,builtin
SEARCH_RAGFLOW_CANDIDATE_TOP_K=
SEARCH_RAGFLOW_TOP_N=
SEARCH_RAGFLOW_SIMILARITY_THRESHOLD=
SEARCH_RAGFLOW_VECTOR_SIMILARITY_WEIGHT=
SEARCH_RAGFLOW_RERANK_ID=
SEARCH_RAGFLOW_KEYWORD=
SEARCH_RAGFLOW_HIGHLIGHT=
SEARCH_RAGFLOW_CROSS_LANGUAGES=
SEARCH_RAGFLOW_USE_KG=
SEARCH_RAGFLOW_TOC_ENHANCE=
SEARCH_ANSWER_GENERATION_MODE=ragflow_chat
RAGFLOW_SEARCH_ANSWER_CHAT_NAME=connector_search_answer
RAGFLOW_SEARCH_ANSWER_CHAT_AUTO_CREATE=true
SEARCH_ANSWER_LLM_BASE_URL=
SEARCH_ANSWER_LLM_MODEL=
SEARCH_ANSWER_LLM_API_KEY=
SEARCH_ANSWER_LLM_TIMEOUT_SECONDS=60
SEARCH_ANSWER_LLM_MAX_TOKENS=900
SEARCH_ANSWER_LLM_TEMPERATURE=0.2

# Öffentliche Seafile-Basis für "Quelle öffnen". Der Search-Service verwendet
# diese Werte nur zum Erzeugen von Browserlinks und bekommt keinen Seafile-Token.
SEARCH_SEAFILE_PUBLIC_BASE_URL=
SEARCH_SEAFILE_FILE_URL_TEMPLATE=

SEARCH_DEFAULT_TOP_K=8
SEARCH_MAX_TOP_K=20
SEARCH_MAX_SELECTED_PROFILES=25
SEARCH_ENABLE_CHAT_MODE=true
SEARCH_ENABLE_RETRIEVAL_MODE=true
SEARCH_SOURCE_PREVIEW_ENABLED=true
SEARCH_SOURCE_HOVER_ENABLED=true
SEARCH_TEXT_FRAGMENT_LINKS_ENABLED=true
SEARCH_DOCUMENT_VIEWER_ENABLED=true
SEARCH_DOCUMENT_VIEWER_MAX_MB=100
SEARCH_RESULT_SNIPPET_CONTEXT_CHARS=420
SEARCH_ANSWER_MAX_SOURCES=8
SEARCH_SOURCE_PREVIEW_SECRET=

# ---------------------------------------------------------------------
# Source: bestehender Seafile Server
# ---------------------------------------------------------------------
# Diese URL muss aus dem Connector-Container erreichbar sein.
# Beispiele:
#   Host-Port:          http://host.docker.internal:18081
#   Reverse Proxy/LAN:  https://seafile.example.local
#   gemeinsames Netz:   http://seafile
SEAFILE_BASE_URL=http://host.docker.internal:18081
SEAFILE_INTERNAL_URL=
SEAFILE_PUBLIC_BASE_URL=
SEAFILE_ADMIN_TOKEN=change-me
SEAFILE_SYNC_USER_TOKEN=change-me
SEAFILE_SYNC_USER_EMAIL=ragflow-sync@example.local
SEAFILE_SKIP_ENCRYPTED_LIBRARIES=true
SEAFILE_SKIP_VIRTUAL_REPOS=true
SEAFILE_REWRITE_DOWNLOAD_URLS=false
SEAFILE_DOWNLOAD_REWRITE_FROM=
SEAFILE_DOWNLOAD_REWRITE_TO=
# Optionaler Override für Browser-Links zum Originaldokument in OpenWebUI-
# Quellenpreviews. Standardmäßig wird aus SEAFILE_PUBLIC_BASE_URL oder
# SEAFILE_BASE_URL ein Link nach /lib/{repo_id}/file{path_quoted} abgeleitet.
# Der Override muss eine absolute http(s)-URL zum Originalsystem sein, nicht zum
# Connector-Preview- oder Proxy-Endpunkt.
# Platzhalter: {repo_id}, {repo_id_quoted}, {path}, {path_quoted},
# {path_query}, {page}, {page_fragment}, {document_id}, {chunk_id}.
SEAFILE_FILE_URL_TEMPLATE=

# Wenn Seafile Download-URLs mit 127.0.0.1 oder einer nur lokal gültigen
# Adresse ausliefert, aktiviere Rewrite:
# SEAFILE_REWRITE_DOWNLOAD_URLS=true
# SEAFILE_DOWNLOAD_REWRITE_FROM=http://127.0.0.1/seafhttp
# SEAFILE_DOWNLOAD_REWRITE_TO=http://host.docker.internal:18081/seafhttp

# ---------------------------------------------------------------------
# Target: bestehender RAGFlow Server
# ---------------------------------------------------------------------
# Diese URL muss aus dem Connector-Container erreichbar sein.
# Beispiele:
#   Host-Port:          http://host.docker.internal:19380
#   Reverse Proxy/LAN:  https://ragflow.example.local
#   gemeinsames Netz:   http://ragflow:9380
RAGFLOW_BASE_URL=http://host.docker.internal:19380
RAGFLOW_INTERNAL_URL=
RAGFLOW_API_KEY=change-me
RAGFLOW_TEMPLATE_DATASET_NAME=connector_template
RAGFLOW_TEMPLATE_AUTO_CREATE=true
RAGFLOW_TEMPLATE_REQUIRED=true
RAGFLOW_TEMPLATE_CHAT_NAME=connector_template_chat
RAGFLOW_SEARCH_TEMPLATE_ENABLED=true
RAGFLOW_SEARCH_TEMPLATE_NAME=search_template
RAGFLOW_SEARCH_TEMPLATE_AUTO_CREATE=true
RAGFLOW_SEARCH_TEMPLATE_REQUIRED=false
RAGFLOW_SEARCH_TEMPLATE_REFRESH_SECONDS=300
# Default: 30 Minuten. Werte unter 60 Sekunden werden abgelehnt, damit keine
# versehentlichen Retry- oder Sync-Stürme entstehen.
RAGFLOW_TEMPLATE_REFRESH_SECONDS=1800
RAGFLOW_REFRESH_DATASET_SETTINGS=true
RAGFLOW_VALIDATE_CREATED_DATASET=true
RAGFLOW_PUBLIC_BASE_URL=
RAGFLOW_DOCUMENT_URL_TEMPLATE=

# ---------------------------------------------------------------------
# Optionales Ziel: bestehende OpenWebUI-Instanz
# ---------------------------------------------------------------------
# Optional. false synchronisiert nur Seafile -> RAGFlow und benötigt keine
# OpenWebUI-Keys, keinen Proxy-Secret und keine OpenWebUI-URL.
# true erzeugt je RAGFlow-Dataset einen RAGFlow-Chat sowie OpenWebUI Tool/Pipe,
# wenn OPENWEBUI_SYNC_MODE=sync oder repair ist.
OPENWEBUI_INTEGRATION_ENABLED=false
OPENWEBUI_BASE_URL=http://host.docker.internal:3000
OPENWEBUI_ADMIN_API_KEY=
OPENWEBUI_SYNC_ON_STARTUP=true
# disabled | dry-run | sync | repair
OPENWEBUI_SYNC_MODE=disabled
OPENWEBUI_CREATE_TOOLS=true
OPENWEBUI_CREATE_PIPES=true
# 180 Sekunden unterstützt lange RAG-Antworten. Für latenzkritische
# OpenWebUI-Proxy-/Edge-Flows 30-60 Sekunden wählen und Reverse-Proxy-Timeouts
# passend setzen.
OPENWEBUI_REQUEST_TIMEOUT_SECONDS=180
OPENWEBUI_FUNCTION_NAMESPACE=ragflow
# ragflow_link | connector_viewer | citation_only | disabled
OPENWEBUI_SOURCE_PREVIEW_MODE=connector_viewer
OPENWEBUI_PROXY_PUBLIC_BASE_URL=
OPENWEBUI_PROXY_INTERNAL_BASE_URL=
OPENWEBUI_PROXY_SHARED_SECRET=
OPENWEBUI_AUTHZ_ENABLED=true
OPENWEBUI_AUTHZ_BASE_URL=http://connector-controller:8080
OPENWEBUI_AUTHZ_SHARED_SECRET=change-me-authz-secret
OPENWEBUI_AUTHZ_FAIL_CLOSED=true
# Optionaler OpenAI-kompatibler Modell-Fallback für die Pipe, falls RAGFlow
# nur Retrieval-Treffer statt einer fertigen Antwort liefert. API-Key nur als
# Runtime-Secret setzen; niemals in Repository-Dateien speichern.
OPENWEBUI_PIPE_ANSWER_SYNTHESIS_ENABLED=false
OPENWEBUI_PIPE_ANSWER_LLM_BASE_URL=
OPENWEBUI_PIPE_ANSWER_LLM_MODEL=
OPENWEBUI_PIPE_ANSWER_LLM_API_KEY=
# Default: 30 Minuten; unabhängig von manuellen Läufen per
# `connector openwebui-sync-once`.
OPENWEBUI_SYNC_INTERVAL_SECONDS=1800
OPENWEBUI_DATASET_ALLOWLIST=

# ---------------------------------------------------------------------
# Connector-State: PostgreSQL und Redis aus diesem Stack
# ---------------------------------------------------------------------
POSTGRES_DB=seafile_ragflow_sync
POSTGRES_USER=sync
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=connector-postgres
POSTGRES_PORT=5432

REDIS_HOST=connector-redis
REDIS_PORT=6379
REDIS_DB=0

# Nur setzen, wenn externe DB/Redis genutzt werden sollen.
DATABASE_URL=
REDIS_URL=

# ---------------------------------------------------------------------
# Datei-Policy
# ---------------------------------------------------------------------
ALLOW_UNKNOWN_TEXT_FILES=true
ALLOW_EXTENSIONS=
DENY_EXTENSIONS=.exe,.dll,.so,.zip,.tar,.gz,.7z,.tmp,.part
TEXT_EXTENSIONS=.ada,.adb,.ads,.txt,.md,.rst,.py,.js,.ts,.java,.c,.cpp,.h,.sql,.xml,.json,.yaml,.yml,.ini,.cfg,.log
BINARY_DIRECT_EXTENSIONS=.pdf,.docx,.xlsx,.pptx,.png,.jpg,.jpeg
DEFAULT_TEXT_INGESTION_STRATEGY=text_projection
PRESERVE_ORIGINAL_FILENAME_IN_METADATA=true
MAX_FILE_SIZE_MB=1024
EXCLUDE_REGEX=(^/\.|/\.|~$|\.tmp$|\.part$)

# ---------------------------------------------------------------------
# RAGFlow-Dataset-Einstellungen
# ---------------------------------------------------------------------
DATASET_SETTINGS_SOURCE=ragflow_current
REPARSE_ON_DATASET_SETTINGS_CHANGE=false

# ---------------------------------------------------------------------
# Scheduling
# ---------------------------------------------------------------------
# Controller- und Reconciler-Automationen laufen standardmäßig alle 30 Minuten.
# Werte unter 60 Sekunden werden abgelehnt. Manuelle Läufe bleiben jederzeit
# über `connector sync-once`, `connector check-live` und
# `connector openwebui-sync-once` möglich.
DISCOVERY_INTERVAL_SECONDS=1800
DELTA_SYNC_INTERVAL_SECONDS=1800
RECONCILE_INTERVAL_SECONDS=1800
FULL_SYNC_ON_MISSING_COMMIT=true

# ---------------------------------------------------------------------
# Delete-/Repair-Policy
# ---------------------------------------------------------------------
# Seafile ist Quelle der Wahrheit. Entfernte Seafile-Dateien/Libraries werden
# in RAGFlow/OpenWebUI nachvollzogen. Extern gelöschte Zielartefakte werden
# dagegen aus Seafile wieder aufgebaut.
DELETE_RAGFLOW_DOCS_ON_SEAFILE_DELETE=true
DELETE_DATASET_WHEN_LIBRARY_DELETED=true
ARCHIVE_DATASET_WHEN_LIBRARY_DELETED=false

# ---------------------------------------------------------------------
# Durchsatz
# ---------------------------------------------------------------------
MAX_CONCURRENT_LIBRARIES=2
UPLOAD_WORKERS=2
PARSE_WORKERS=1
RAGFLOW_UPLOAD_BATCH_SIZE=8
RAGFLOW_PARSE_BATCH_SIZE=16
RAGFLOW_MAX_INFLIGHT_DOCUMENTS=64

# ---------------------------------------------------------------------
# Retry
# ---------------------------------------------------------------------
JOB_MAX_ATTEMPTS=5
JOB_RETRY_BASE_SECONDS=30
JOB_RETRY_MAX_SECONDS=3600

# ---------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------
CACHE_DIR=/cache
TEMP_DIR=/cache/tmp
ALLOW_OUTBOUND_INTERNET=false
DISABLE_TELEMETRY=true

# ---------------------------------------------------------------------
# Startup / Bootstrap
# ---------------------------------------------------------------------
CONNECTOR_AUTO_INIT_DB=true
# skip | infra | live
# infra ist der adminfreundliche Default: Container, Dashboard und Logs starten
# auch dann, wenn ein externes System oder ein RAGFlow-Parser-Asset noch fehlt.
# Für strikte Starts kann live gesetzt werden.
CONNECTOR_STARTUP_CHECK=infra
CONNECTOR_STARTUP_MAX_WAIT_SECONDS=300
CONNECTOR_STARTUP_SLEEP_SECONDS=5
CONNECTOR_BOOTSTRAP_CHECK_LIVE=false
CONNECTOR_FALLBACK_CACHE_DIR=/tmp/seafile-ragflow-connector/cache
CONNECTOR_FALLBACK_TEMP_DIR=/tmp/seafile-ragflow-connector/cache/tmp
